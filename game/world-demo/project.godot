; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Tim's House — World Demo"
config/description="Voxel medieval world demo — browser and desktop."
config/version="0.1.0"
run/main_scene="res://ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

ScreenshotHelper="*res://autoload/screenshot_helper.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[layer_names]

3d_physics/layer_1="world"
3d_physics/layer_2="player"

[physics]

3d/default_gravity=12.0

[editor_plugins]

enabled=PackedStringArray("res://addons/godotiq/plugin.cfg")

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
